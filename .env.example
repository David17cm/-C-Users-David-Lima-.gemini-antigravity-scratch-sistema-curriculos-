# Variáveis de Ambiente — sistema-curriculos
# Copie este arquivo como .env e preencha os valores reais.
# NUNCA commite o arquivo .env real no git!

# === SUPABASE ===
# URL do seu projeto Supabase (encontrado em Project Settings > API)
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co

# Chave anônima pública do Supabase (encontrada em Project Settings > API > anon key)
# Esta chave é pública (exposta no frontend), por isso o RLS é obrigatório!
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.SUA_CHAVE_AQUI

# === MERCADO PAGO (opcional — integração futura) ===
# Access Token PRIVADO do Mercado Pago — NUNCA coloque isso no frontend!
# Use apenas em Edge Functions (Supabase) ou backend dedicado.
# VITE_MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxx
